</main>

<script>
    // 1. Get Slug from Server
    const currentSlug = "<%= typeof slug !== 'undefined' ? slug : 'default' %>";
    
    // 2. Fetch Data
    const data = servicesDB[currentSlug] || servicesDB['default'];

    // 3. Update Hero
    document.getElementById('hero-title').innerHTML = data.title;
    document.getElementById('hero-subtitle').innerText = data.subtitle;
    document.getElementById('hero-desc').innerText = data.desc;
    document.getElementById('hero-img').src = data.img;
    document.getElementById('service-input').value = data.title;
    document.getElementById('price-tag').innerText = data.price;

    // 4. Inject Premium Feature Cards
    const grid = document.getElementById('features-grid');
    grid.innerHTML = '';
    
    const icons = ['fa-rocket', 'fa-shield-alt', 'fa-bolt', 'fa-mobile-alt'];

    data.features.forEach((feat, index) => {
        const icon = icons[index % icons.length];
        grid.innerHTML += `
            <div class="premium-card p-6 rounded-2xl group cursor-default">
                <div class="w-12 h-12 rounded-full bg-[#00f3ff]/10 flex items-center justify-center text-[#00f3ff] text-xl mb-4 group-hover:scale-110 transition duration-300">
                    <i class="fas ${icon}"></i>
                </div>
                <h4 class="text-white font-bold text-lg mb-2">${feat}</h4>
                <p class="text-gray-500 text-sm">Engineered for maximum impact and long-term scalability.</p>
            </div>
        `;
    });

    // 5. GSAP Reveal Animation
    if(typeof gsap !== 'undefined') {
        gsap.from(".gsap-reveal", {
            y: 50, opacity: 0, duration: 1, stagger: 0.1, ease: "power3.out"
        });
    }
</script>

