<script>
    function calculate() {
        // ... (Same Calculation Logic as before) ...
        let platform = parseInt(document.querySelector('input[name="platform"]:checked').value);
        let type = parseInt(document.querySelector('input[name="type"]:checked').value);
        let design = parseFloat(document.querySelector('input[name="design"]:checked').value);
        let pages = parseInt(document.getElementById('pageRange').value);
        let pagesCost = (pages > 5) ? (pages - 5) * 1000 : 0;
        
        let features = 0;
        document.querySelectorAll('.feature-check:checked').forEach(el => features += parseInt(el.value));

        let services = 0;
        document.querySelectorAll('.service-check:checked').forEach(el => services += parseInt(el.value));
        
        let subTotal = (platform + type + pagesCost + features) * design;
        let total = subTotal + services;

        let discount = 0;
        if(total > 100000) {
            discount = total * 0.10;
            total = total - discount;
            document.getElementById('discountRow').classList.remove('hidden');
        } else {
            document.getElementById('discountRow').classList.add('hidden');
        }

        document.getElementById('d_platform').innerText = platform.toLocaleString();
        document.getElementById('d_type').innerText = type.toLocaleString();
        document.getElementById('d_pages_count').innerText = pages;
        document.getElementById('d_pages_cost').innerText = pagesCost.toLocaleString();
        document.getElementById('d_features').innerText = features.toLocaleString();
        document.getElementById('d_services').innerText = services.toLocaleString();
        document.getElementById('d_design').innerText = design;
        document.getElementById('d_discount').innerText = Math.round(discount).toLocaleString();
        document.getElementById('d_total').innerText = Math.round(total).toLocaleString('en-IN');
    }

    // --- NEW DETAILED WHATSAPP LOGIC ---
    function sendWhatsApp() {
        // 1. Gather Data Text (Names, not just numbers)
        let platformName = document.querySelector('input[name="platform"]:checked').nextElementSibling.dataset.name;
        let typeName = document.querySelector('input[name="type"]:checked').nextElementSibling.dataset.name;
        let designName = document.querySelector('input[name="design"]:checked').nextElementSibling.dataset.name;
        let pagesCount = document.getElementById('pageRange').value;
        let totalCost = document.getElementById('d_total').innerText;
        let quoteID = document.getElementById('quoteId').innerText;

        // 2. Gather Feature Lists
        let featureList = [];
        document.querySelectorAll('.feature-check:checked').forEach(el => {
            featureList.push(el.nextElementSibling.dataset.name);
        });
        
        let serviceList = [];
        document.querySelectorAll('.service-check:checked').forEach(el => {
            serviceList.push(el.nextElementSibling.dataset.name);
        });

        // 3. Format Message with Line Breaks (%0a) and Bold (*)
        let msg = `🚀 *New Project Inquiry* (Webglut Estimator)%0a`;
        msg += `---------------------------%0a`;
        msg += `*Quote ID:* ${quoteID}%0a`;
        msg += `*Platform:* ${platformName}%0a`;
        msg += `*Type:* ${typeName}%0a`;
        msg += `*Design Tier:* ${designName}%0a`;
        msg += `*Scale:* ${pagesCount} Pages/Screens%0a`;
        
        if(featureList.length > 0) {
            msg += `---------------------------%0a`;
            msg += `*Features Selected:*%0a`;
            featureList.forEach(f => msg += `✅ ${f}%0a`);
        }

        if(serviceList.length > 0) {
            msg += `---------------------------%0a`;
            msg += `*Services Selected:*%0a`;
            serviceList.forEach(s => msg += `🛠 ${s}%0a`);
        }

        msg += `---------------------------%0a`;
        msg += `💰 *Est. Budget:* ₹${totalCost}%0a`;
        msg += `---------------------------%0a`;
        msg += `I am interested in this configuration. Let's discuss.`;

        // 4. Send
        window.open(`https://wa.me/919115025412?text=${msg}`, '_blank');
    }

    // Init
    document.getElementById('quoteId').innerText = "WG-" + Math.floor(Math.random() * 9000 + 1000);
    calculate();
</script>

