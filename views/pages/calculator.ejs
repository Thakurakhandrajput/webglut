<%- include('../partials/header') %>

<style>
    /* --- ULTIMATE CONFIGURATOR CSS --- */
    
    .config-section {
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 16px;
        padding: 30px;
        margin-bottom: 30px;
        transition: 0.3s;
    }
    .config-section:hover {
        border-color: rgba(255, 255, 255, 0.1);
        background: rgba(255, 255, 255, 0.03);
    }

    /* Cards Selection (Radio) */
    .selection-card {
        cursor: pointer;
        border: 1px solid rgba(255, 255, 255, 0.1);
        background: rgba(0, 0, 0, 0.3);
        border-radius: 12px;
        padding: 20px;
        transition: all 0.2s;
        height: 100%;
        position: relative;
        overflow: hidden;
    }
    .selection-card:hover {
        transform: translateY(-3px);
        border-color: rgba(0, 243, 255, 0.3);
    }
    
    /* Checked State (Radio) */
    input:checked + .selection-card {
        background: rgba(0, 243, 255, 0.05);
        border-color: #00f3ff;
        box-shadow: 0 0 15px rgba(0, 243, 255, 0.1);
    }
    input:checked + .selection-card::after {
        content: '\f00c'; font-family: 'Font Awesome 6 Free'; font-weight: 900;
        position: absolute; top: 10px; right: 10px; color: #00f3ff;
    }

    /* --- NEW PREMIUM FEATURE MODULES (Checkbox) --- */
    .feature-module {
        cursor: pointer;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(255, 255, 255, 0.01);
        border-radius: 10px;
        padding: 15px;
        display: flex;
        align-items: center;
        gap: 15px;
        transition: all 0.3s ease;
    }
    .feature-module:hover {
        background: rgba(255, 255, 255, 0.05);
    }
    
    /* Checked State (Checkbox) */
    input:checked + .feature-module {
        background: linear-gradient(90deg, rgba(0, 243, 255, 0.1), transparent);
        border-color: #00f3ff;
        box-shadow: 0 0 10px rgba(0, 243, 255, 0.1) inset;
    }
    input:checked + .feature-module i {
        color: #00f3ff;
        text-shadow: 0 0 10px #00f3ff;
    }
    input:checked + .feature-module .check-icon {
        opacity: 1; transform: scale(1);
    }

    /* Custom Checkbox Hidden */
    .hidden-input { display: none; }

    /* Sticky Sidebar */
    .receipt-panel {
        background: #0a0a0a;
        border: 1px solid rgba(0, 243, 255, 0.2);
        border-radius: 20px;
        box-shadow: 0 0 40px rgba(0,0,0,0.8);
    }
</style>

