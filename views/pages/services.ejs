<%- include('../partials/header') %>

<style>
    /* Global Settings */
    html, body {
        background-color: #000000;
        font-family: 'Outfit', sans-serif;
        overflow-x: hidden;
    }

    /* MATTE CARD STYLE (Screenshot Reference) */
    .service-card {
        background-color: #0a0a0a; /* Matte Black */
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 24px; /* Soft Rounded Corners */
        transition: all 0.3s ease;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
    }

    /* Hover Effect */
    .service-card:hover {
        border-color: #00f3ff;
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    }

    /* Icon Box Style */
    .icon-box {
        width: 60px;
        height: 60px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        margin-bottom: 1.5rem;
        transition: 0.3s;
    }
    
    /* Bullet Points */
    .feature-list {
        list-style: none;
        padding: 0;
        margin-top: auto; /* Push to bottom */
        padding-top: 1.5rem;
    }
    .feature-list li {
        color: #666;
        font-size: 0.9rem;
        margin-bottom: 0.5rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .feature-list li::before {
        content: '•';
        color: #00f3ff;
        font-weight: bold;
    }
    
    /* Reveal Animation */
    .gsap-reveal { opacity: 0; transform: translateY(30px); }
</style>

