<%- include('../partials/scripts') %>

<script>
    // SCROLL REVEAL LOGIC
    if (typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
        gsap.registerPlugin(ScrollTrigger);
        gsap.utils.toArray('.gsap-reveal').forEach(function(elem) {
            gsap.to(elem, {
                scrollTrigger: {
                    trigger: elem,
                    start: "top 90%",
                    toggleActions: "play none none none"
                },
                y: 0,
                opacity: 1,
                duration: 0.6,
                ease: "power2.out"
            });
        });
    }
</script>
