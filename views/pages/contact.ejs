<%- include('../partials/header') %>

<style>
    /* GLOBAL SETTINGS */
    html, body {
        background-color: #050505;
        font-family: 'Outfit', sans-serif;
        overflow-x: hidden;
    }

    /* 1. HERO SECTION */
    .contact-hero {
        padding-top: 150px;
        padding-bottom: 60px;
        background: radial-gradient(circle at top right, rgba(0, 243, 255, 0.05) 0%, rgba(0,0,0,0) 50%);
    }

    /* 2. FORM STYLING */
    .contact-card {
        background: #0a0a0a;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 30px;
        padding: 40px;
    }
    .input-group {
        position: relative;
        margin-bottom: 30px;
    }
    .input-field {
        width: 100%;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.1);
        padding: 15px 20px;
        border-radius: 12px;
        color: white;
        transition: 0.3s;
        outline: none;
    }
    .input-field:focus {
        border-color: #00f3ff;
        background: rgba(0, 243, 255, 0.02);
        box-shadow: 0 0 20px rgba(0, 243, 255, 0.1);
    }
    
    /* 3. FAQ ACCORDION */
    .faq-item {
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        padding: 20px 0;
    }
    .faq-question {
        cursor: pointer;
        display: flex;
        justify-content: space-between;
        align-items: center;
        color: white;
        font-weight: 600;
        font-size: 1.1rem;
        transition: 0.3s;
    }
    .faq-question:hover { color: #00f3ff; }
    .faq-answer {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.4s ease-out;
        color: #888;
        line-height: 1.6;
        margin-top: 0;
    }
    .faq-item.active .faq-answer {
        max-height: 200px;
        margin-top: 15px;
    }
    .faq-item.active .faq-icon { transform: rotate(180deg); color: #00f3ff; }

    /* Reveal Animation */
    .fade-up { opacity: 0; transform: translateY(30px); }
</style>

<main>

    <section class="contact-hero container mx-auto px-6">
        <div class="max-w-4xl">
            <span class="px-4 py-2 rounded-full border border-[#00f3ff]/30 bg-[#00f3ff]/10 text-[#00f3ff] text-xs font-bold uppercase tracking-[0.2em] mb-6 inline-block fade-up">
                Get In Touch
            </span>
            <h1 class="text-6xl md:text-8xl font-bold text-white mb-6 fade-up">
                Let's Build Your <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#00f3ff] to-purple-600">Reality.</span>
            </h1>
        </div>
    </section>

    <section class="pb-32 container mx-auto px-6">
        <div class="grid lg:grid-cols-2 gap-20">

            <div class="fade-up">
                <div class="contact-card">
                    <h2 class="text-2xl font-bold text-white mb-8">Send a Message</h2>
                    <form action="/contact-submit" method="POST">
                        
                        <div class="grid md:grid-cols-2 gap-6">
                            <div class="input-group">
                                <label class="text-xs text-gray-500 uppercase font-bold mb-2 block">Full Name</label>
                                <input type="text" name="name" class="input-field" placeholder="John Doe" required>
                            </div>
                            <div class="input-group">
                                <label class="text-xs text-gray-500 uppercase font-bold mb-2 block">Email Address</label>
                                <input type="email" name="email" class="input-field" placeholder="john@example.com" required>
                            </div>
                        </div>

                        <div class="grid md:grid-cols-2 gap-6">
                            <div class="input-group">
                                <label class="text-xs text-gray-500 uppercase font-bold mb-2 block">Mobile Number <span class="text-[#00f3ff]">*</span></label>
                                <input type="tel" name="phone" class="input-field" placeholder="+91 98765 43210" required>
                            </div>

                            <div class="input-group">
                                <label class="text-xs text-gray-500 uppercase font-bold mb-2 block">Subject</label>
                                <select name="service" class="input-field">
                                    <option value="web">Web Development</option>
                                    <option value="app">App Development</option>
                                    <option value="seo">SEO Optimization</option>
                                    <option value="other">Other Inquiry</option>
                                </select>
                            </div>
                        </div>

                        <div class="input-group">
                            <label class="text-xs text-gray-500 uppercase font-bold mb-2 block">Your Message</label>
                            <textarea name="message" class="input-field" rows="5" placeholder="Tell us about your project..."></textarea>
                        </div>

                        <button type="submit" class="w-full py-5 bg-[#00f3ff] text-black font-bold rounded-xl hover:scale-[1.02] transition shadow-[0_10px_30px_rgba(0,243,255,0.2)]">
                            Launch Project Request
                        </button>
                    </form>

                    <div class="mt-12 pt-10 border-t border-white/5 grid grid-cols-2 gap-6">
                        <div>
                            <span class="text-gray-500 text-xs uppercase font-bold block mb-2">WhatsApp Us</span>
                            <a href="https://wa.me/919115025412" class="text-white font-bold hover:text-[#00f3ff]">+91 9115025412</a>
                        </div>
                        <div>
                            <span class="text-gray-500 text-xs uppercase font-bold block mb-2">Email Us</span>
                            <a href="mailto:contact@webglut.in" class="text-white font-bold hover:text-[#00f3ff]">contact@webglut.in</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="fade-up" style="transition-delay: 0.2s;">
                <h2 class="text-3xl font-bold text-white mb-10">Common <span class="text-[#00f3ff]">Questions</span></h2>
                
                <div class="faq-accordion">
                    <div class="faq-item">
                        <div class="faq-question" onclick="toggleFaq(this)">
                            <span>How much does a custom website cost?</span>
                            <i class="fas fa-chevron-down faq-icon text-sm"></i>
                        </div>
                        <div class="faq-answer">
                            Pricing depends on features, complexity, and tech stack. Simple landing pages start at a different range compared to complex SaaS platforms. Contact us for a free detailed quotation tailored to your needs.
                        </div>
                    </div>

                    <div class="faq-item">
                        <div class="faq-question" onclick="toggleFaq(this)">
                            <span>What is the average project timeline?</span>
                            <i class="fas fa-chevron-down faq-icon text-sm"></i>
                        </div>
                        <div class="faq-answer">
                            A standard high-performance website usually takes 2-4 weeks, while complex mobile applications or SaaS products can take 8-12 weeks from design to deployment.
                        </div>
                    </div>

                    <div class="faq-item">
                        <div class="faq-question" onclick="toggleFaq(this)">
                            <span>Do you provide maintenance after launch?</span>
                            <i class="fas fa-chevron-down faq-icon text-sm"></i>
                        </div>
                        <div class="faq-answer">
                            Yes, Webglut provides dedicated maintenance packages. We handle server updates, security patches, malware scanning, and content updates so you can focus on your business.
                        </div>
                    </div>

                    <div class="faq-item">
                        <div class="faq-question" onclick="toggleFaq(this)">
                            <span>Will my app be listed on Play Store/App Store?</span>
                            <i class="fas fa-chevron-down faq-icon text-sm"></i>
                        </div>
                        <div class="faq-answer">
                            Absolutely. We handle the entire technical submission process for both Google Play Store and Apple App Store, ensuring your app meets all their security and design guidelines.
                        </div>
                    </div>

                    <div class="faq-item">
                        <div class="faq-question" onclick="toggleFaq(this)">
                            <span>What is a Digital Smart Card (NFC)?</span>
                            <i class="fas fa-chevron-down faq-icon text-sm"></i>
                        </div>
                        <div class="faq-answer">
                            It's a modern business card with an embedded chip. When tapped on a smartphone, it instantly opens your digital profile, links, and contact details. No app installation is required for the receiver.
                        </div>
                    </div>
                </div>

                <div class="mt-16 p-8 bg-white/2 rounded-2xl border border-dashed border-white/10">
                    <p class="text-gray-400 text-sm">
                        <i class="fas fa-shield-alt text-[#00f3ff] mr-2"></i> 
                        Your data is 100% secure. We never share your project ideas or contact details with third parties.
                    </p>
                </div>
            </div>

        </div>
    </section>

</main>

<%- include('../partials/footer') %>
<%- include('../partials/scripts') %>

<script>
    // 1. FAQ TOGGLE LOGIC
    function toggleFaq(element) {
        const item = element.parentElement;
        const isActive = item.classList.contains('active');
        
        // Close all other FAQs
        document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('active'));
        
        // Open the clicked one if it wasn't active
        if (!isActive) {
            item.classList.add('active');
        }
    }

    // 2. GSAP REVEAL
    if (typeof gsap !== 'undefined') {
        gsap.to('.fade-up', {
            y: 0,
            opacity: 1,
            duration: 0.8,
            stagger: 0.2,
            ease: "power2.out",
            scrollTrigger: {
                trigger: '.contact-hero',
                start: "top 80%"
            }
        });
    }
</script>
