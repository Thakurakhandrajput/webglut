<%- include('../partials/header') %>

<main class="bg-[#050505] min-h-screen flex items-center justify-center text-center px-6">
    
    <div class="max-w-lg w-full">
        <div class="mb-8 relative inline-block">
            <div class="w-24 h-24 rounded-full border-2 border-[#00f3ff] flex items-center justify-center mx-auto shadow-[0_0_30px_rgba(0,243,255,0.3)]">
                <i class="fas fa-check text-4xl text-[#00f3ff] drop-shadow-[0_0_10px_rgba(0,243,255,0.8)]"></i>
            </div>
            <div class="absolute inset-0 border border-[#00f3ff] rounded-full animate-ping opacity-20"></div>
        </div>

        <h1 class="text-4xl md:text-5xl font-display font-bold text-white mb-4">Request Received!</h1>
        <p class="text-gray-400 text-lg mb-10">
            Thank you for contacting <span class="text-[#00f3ff] font-bold">Webglut</span>. <br>
            Our team will connect with you shortly via WhatsApp.
        </p>

        <a href="/" class="px-8 py-3 bg-white/5 border border-white/10 text-white rounded-full hover:bg-[#00f3ff] hover:text-black hover:border-[#00f3ff] transition duration-300 font-bold uppercase text-xs tracking-widest">
            Back to Home
        </a>
    </div>

</main>

<script>
    setTimeout(() => {
        window.location.href = "/";
    }, 5000); // 5 second baad home page par bhej dega
</script>

