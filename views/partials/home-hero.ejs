<section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-20">
    
    <div id="hero-spotlight" class="absolute inset-0 pointer-events-none z-0 opacity-40" 
         style="background: radial-gradient(600px circle at var(--x) var(--y), rgba(0, 243, 255, 0.15), transparent 40%);">
    </div>
    
    <div class="absolute inset-0 bg-[url('https://grainy-gradients.vercel.app/noise.svg')] opacity-10 z-0 pointer-events-none"></div>

    <div class="container mx-auto px-6 relative z-10 grid lg:grid-cols-2 gap-12 items-center">
        
        <div class="text-center lg:text-left">
            
            <div id="hero-badge" class="opacity-0 translate-y-10 transition-all duration-1000 ease-out inline-flex items-center gap-2 px-3 py-1 rounded-full border border-[#00f3ff]/30 bg-[#00f3ff]/5 backdrop-blur-md mb-8">
                <span class="relative flex h-2 w-2">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#00f3ff] opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-2 w-2 bg-[#00f3ff]"></span>
                </span>
